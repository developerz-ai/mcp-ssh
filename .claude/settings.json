{
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "Bash(cargo *:*)",
      "Bash(bin/*:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(git fetch:*)",
      "Bash(git checkout:*)",
      "Bash(gh pr *:*)",
      "Bash(docker *:*)",
      "Bash(cargo deb:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash(git commit:*)",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/pre-commit.sh"
          }
        ]
      },
      {
        "matcher": "Bash(git push:*)",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/pre-push.sh"
          }
        ]
      }
    ]
  }
}
